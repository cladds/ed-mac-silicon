# ed-launch.env - shared environment for the ED prefix and launchers.
# Sourced by scripts via:  set -a; source config/ed-launch.env; set +a

# Where the Elite Dangerous prefix lives.
ED_PREFIX="$HOME/Games/elite-dangerous"

# Where companion tools (EDDiscovery etc.) live, isolated from ED.
TOOLS_PREFIX="$HOME/Games/ed-tools"

# 64-bit only. 32-bit prefixes are deprecated and ED is x64.
WINEARCH=win64

# Default WINEPREFIX is the ED one. launch-eddiscovery.sh overrides.
WINEPREFIX="$ED_PREFIX"

# Where Steam installs ED inside the prefix (Steam default).
ED_GAME_DIR="$ED_PREFIX/drive_c/Program Files (x86)/Steam/steamapps/common/Elite Dangerous"

# min-ed-launcher install location inside the prefix.
MIN_ED_LAUNCHER_DIR="$ED_PREFIX/drive_c/Program Files/min-ed-launcher"

# GPTK Metal HUD overlay. 0 = off, 1 = on (handy for FPS / VRAM checks).
MTL_HUD_ENABLED=0

# Reduce Wine log noise during play. Override with --debug on launch-ed.sh.
WINEDEBUG=-all

# D3DMetal options. Leave at defaults unless you know why you're changing them.
# D3DM_SUPPORT_DXR=0
# D3DM_ENABLE_GPU_UPLOAD_HEAPS=0
